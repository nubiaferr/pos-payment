<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_screen"
    tools:context=".presentation.fragment.PaymentFragment">

    <!-- ── Toolbar ─────────────────────────────────────────────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/surface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingTop="30dp"
            app:title="@string/title_new_payment"
            app:titleTextAppearance="@style/TextAppearance.App.Toolbar"
            app:titleTextColor="@color/on_surface" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Scrollable content ──────────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <!-- ── Amount input card ──────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:strokeColor="@color/stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.05"
                        android:text="@string/label_amount"
                        android:textAllCaps="true"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_amount"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:endIconMode="clear_text"
                        app:endIconTint="@color/on_surface_variant">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_amount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:textColor="@color/on_surface"
                            android:textSize="28sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!--
                        Instalments section — only visible when Credit is selected.
                        Controlled by PaymentFragment.selectMethod().

                        Inside, two states are toggled reactively via instalmentInputVisible:
                        1. tv_instalments_hint  — shown when amount < R$ 10,00
                        2. til_installments     — shown when amount >= R$ 10,00
                    -->
                    <LinearLayout
                        android:id="@+id/layout_installments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!--
                            Hint shown when amount is below the instalment minimum.
                            Visibility: gone when til_installments is visible, visible otherwise.
                        -->
                        <TextView
                            android:id="@+id/tv_instalments_hint"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/hint_instalments_minimum"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp"
                            android:visibility="visible"
                            tools:visibility="visible" />

                        <!--
                            Input row — shown when amount >= R$ 10,00.
                            Visibility: gone by default, shown reactively.
                        -->
                        <LinearLayout
                            android:id="@+id/layout_instalment_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/label_instalments"
                                android:textColor="@color/on_surface"
                                android:textSize="14sp" />

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/til_installments"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                                android:layout_width="100dp"
                                android:layout_height="wrap_content"
                                app:endIconMode="clear_text"
                                app:endIconTint="@color/on_surface_variant">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_installments"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:inputType="number"
                                    android:textColor="@color/on_surface"
                                    android:textSize="16sp" />

                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                        <!--
                            Per-instalment breakdown shown in real time.
                            e.g. "12x de R$ 50,00"
                            Controlled by instalmentSummary StateFlow.
                        -->
                        <TextView
                            android:id="@+id/tv_instalment_summary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:visibility="gone"
                            tools:text="12x de R$ 50,00"
                            tools:visibility="visible" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Payment method label ───────────────────────────────────── -->
            <TextView
                android:id="@+id/tv_method_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:letterSpacing="0.05"
                android:text="@string/label_payment_method"
                android:textAllCaps="true"
                android:textColor="@color/on_surface_variant"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/card_amount" />

            <!-- ── Payment method buttons ─────────────────────────────────── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/group_payment_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_method_label">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_credit"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:text="@string/payment_method_credit"
                    android:textColor="@color/color_payment_method_button_content"
                    android:textSize="14sp"
                    app:backgroundTint="@color/color_payment_method_button_bg"
                    app:cornerRadius="12dp"
                    app:layout_constraintEnd_toStartOf="@id/btn_debit"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeColor="@color/color_payment_method_button_content"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_debit"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:text="@string/payment_method_debit"
                    android:textColor="@color/color_payment_method_button_content"
                    android:textSize="14sp"
                    app:backgroundTint="@color/color_payment_method_button_bg"
                    app:cornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btn_credit"
                    app:layout_constraintTop_toTopOf="parent"
                    app:strokeColor="@color/color_payment_method_button_content"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pix"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="8dp"
                    android:text="@string/payment_method_pix"
                    android:textColor="@color/color_payment_method_button_content"
                    android:textSize="14sp"
                    app:backgroundTint="@color/color_payment_method_button_bg"
                    app:cornerRadius="12dp"
                    app:layout_constraintEnd_toStartOf="@id/btn_voucher"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btn_credit"
                    app:strokeColor="@color/color_payment_method_button_content"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_voucher"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:text="@string/payment_method_voucher"
                    android:textColor="@color/color_payment_method_button_content"
                    android:textSize="14sp"
                    app:backgroundTint="@color/color_payment_method_button_bg"
                    app:cornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btn_pix"
                    app:layout_constraintTop_toBottomOf="@id/btn_debit"
                    app:strokeColor="@color/color_payment_method_button_content"
                    app:strokeWidth="1dp" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ── Confirm button ─────────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_confirm"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="@string/btn_confirm_payment"
                android:textSize="15sp"
                android:enabled="false"
                app:cornerRadius="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/group_payment_buttons" />

            <!-- ── Loading state ──────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/layout_loading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="64dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_confirm">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progress_bar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@color/primary"
                    app:trackColor="@color/stroke"
                    app:trackThickness="4dp" />

                <TextView
                    android:id="@+id/tv_loading_message"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/loading_processing_payment"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- ── Error state ────────────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/error_container"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layout_loading"
                app:strokeColor="@color/error"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/error_payment_not_processed"
                            android:textColor="@color/error"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_error_message"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingMultiplier="1.4"
                        android:textColor="@color/on_error_container"
                        android:textSize="13sp"
                        tools:text="Parcelamento indisponível abaixo de R$10,00." />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_retry"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/btn_retry"
                        android:textSize="13sp"
                        app:cornerRadius="8dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>