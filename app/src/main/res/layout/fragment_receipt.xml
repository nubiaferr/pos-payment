<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_screen"
    tools:context=".presentation.fragment.ReceiptFragment">

    <!-- ── Toolbar ─────────────────────────────────────────────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/surface"
        android:paddingTop="30dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_close"
            app:navigationIconTint="@color/on_surface"
            app:title="@string/title_receipt"
            app:titleTextAppearance="@style/TextAppearance.App.Toolbar"
            app:titleTextColor="@color/on_surface" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Scrollable content ──────────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ── Success badge ──────────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="24dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardBackgroundColor="@color/success_container"
                    app:cardCornerRadius="36dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_check"
                        app:tint="@color/success" />

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/receipt_payment_approved"
                    android:textColor="@color/on_surface"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tv_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/primary"
                    android:textSize="32sp"
                    tools:text="R$ 150.00" />

            </LinearLayout>

            <!-- ── Transaction details card ───────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Method -->
                    <LinearLayout style="@style/ReceiptRow">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/receipt_label_method"
                            style="@style/ReceiptLabel" />
                        <TextView
                            android:id="@+id/tv_method"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/ReceiptValue"
                            tools:text="Credit" />
                    </LinearLayout>

                    <View style="@style/Divider" />

                    <!-- Instalments -->
                    <LinearLayout
                        android:id="@+id/row_instalments"
                        style="@style/ReceiptRow">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/receipt_label_instalments"
                            style="@style/ReceiptLabel" />
                        <TextView
                            android:id="@+id/tv_instalments"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/ReceiptValue"
                            tools:text="3x of R$ 50.00" />
                    </LinearLayout>

                    <View
                        android:id="@+id/divider_instalments"
                        style="@style/Divider" />

                    <!-- Status -->
                    <LinearLayout style="@style/ReceiptRow">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/receipt_label_status"
                            style="@style/ReceiptLabel" />
                        <TextView
                            android:id="@+id/tv_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/ReceiptValue"
                            tools:text="Approved" />
                    </LinearLayout>

                    <View style="@style/Divider" />

                    <!-- Auth code -->
                    <LinearLayout style="@style/ReceiptRow">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/receipt_label_auth_code"
                            style="@style/ReceiptLabel" />
                        <TextView
                            android:id="@+id/tv_auth_code"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/ReceiptValue"
                            tools:text="AUTH-482910" />
                    </LinearLayout>

                    <View style="@style/Divider" />

                    <!-- Date -->
                    <LinearLayout style="@style/ReceiptRow">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/receipt_label_date"
                            style="@style/ReceiptLabel" />
                        <TextView
                            android:id="@+id/tv_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/ReceiptValue"
                            tools:text="28/03/2025 14:32" />
                    </LinearLayout>

                    <View style="@style/Divider" />

                    <!-- Transaction ID -->
                    <LinearLayout style="@style/ReceiptRow">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/receipt_label_transaction_id"
                            style="@style/ReceiptLabel" />
                        <TextView
                            android:id="@+id/tv_transaction_id"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:maxWidth="160dp"
                            style="@style/ReceiptValue"
                            tools:text="a1b2c3d4-e5f6" />
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── New payment button ─────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_new_payment"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="@string/btn_new_payment"
                android:textSize="15sp"
                app:cornerRadius="12dp" />

            <!-- ── Cancel transaction button ──────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel_transaction"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_cancel_transaction"
                android:textColor="@color/error"
                android:textSize="14sp"
                app:cornerRadius="12dp"
                app:rippleColor="@color/error_container" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>